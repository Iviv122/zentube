{
  "manifest_version": 3,
  "name": "Zentube",
  "description": "Customization for youtube clearance",
  "home_page": "",
  "version": "1.0",
  "icons": {
    "32": "icons/icon32.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zentube@iviv122",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "action": {
    "default_icon": "icons/icon32.png",
    "default_title": "Zentube-settings",
    "default_popup": "options/options.html"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "clearer.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options/options.html"
  },
  "permissions": [
    "storage"
  ]
}