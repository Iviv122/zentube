{
  "manifest_version": 2,
  "name": "Zentube",
  "version": "1.0",
  "description": "Customization for youtube clearance",
  "icons": {
    "32": "icons/icon32.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "zentube@addon"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*"
      ],
      "js": [
        "clearer.js"
      ]
    }
  ],
  "options_ui": {
    "page": "options/options.html"
  },
  "permissions": [
    "storage"
  ]
}